# Copy to .env.local and fill in your Supabase credentials

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used to bootstrap the admin account — keep secret
ADMIN_BOOTSTRAP_SECRET=change-this-to-a-long-random-string

# Your deployment URL (used in invite links)
# Set to your Netlify site URL in production, e.g. https://wc26tips.netlify.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
